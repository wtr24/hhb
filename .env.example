# ============================================================
# HHBFin Terminal — Environment Configuration
# ============================================================
# Copy this file to .env and fill in API keys.
# All API keys are FREE — no credit card required.
# cp .env.example .env
# ============================================================

# --- Database (TimescaleDB) ---
POSTGRES_USER=hhbfin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=hhbfin
DATABASE_URL=postgresql://hhbfin:changeme@timescaledb:5432/hhbfin

# --- Redis (Cache + Pub/Sub + Celery Broker) ---
REDIS_URL=redis://redis:6379/0

# ============================================================
# FREE API KEYS — One-time signup, no credit card required
# ============================================================

# 1. FRED (Federal Reserve Economic Data — GDP, CPI, yield curves, 800k+ series)
#    Signup: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# 2. Finnhub (Real-time quotes, company news, insider data, short interest)
#    Signup: https://finnhub.io/register
FINNHUB_API_KEY=

# 3. Financial Modeling Prep (Income statements, balance sheets, DCF models)
#    Signup: https://site.financialmodelingprep.com/developer/docs
FMP_API_KEY=

# 4. Alpha Vantage (Technical indicators — RSI, MACD, Bollinger Bands)
#    Signup: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# 5. EIA (US Energy Information Administration — oil, gas, electricity, inventories)
#    Signup: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# 6. BLS (US Bureau of Labor Statistics — payrolls, CPI, PPI)
#    Signup: https://data.bls.gov/registrationEngine/
BLS_API_KEY=

# 7. Companies House (UK company filings, director transactions, ownership)
#    Signup: https://developer.company-information.service.gov.uk/
COMPANIES_HOUSE_API_KEY=
